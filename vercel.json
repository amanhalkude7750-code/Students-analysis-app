{
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/ai/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/frontend/home.html"
    },
    {
      "source": "/accessibility-portal/assets/(.*)",
      "destination": "/frontend/accessibility-portal/assets/$1"
    },
    {
      "source": "/accessibility-portal/(.*)",
      "destination": "/frontend/accessibility-portal/index.html"
    },
    {
      "source": "/:path((?!api/).*)",
      "destination": "/frontend/:path"
    }
  ]
}